# ==== Demo 模式（离线演示开关） ====
# 设为 true 时，所有 MCP URL 会被强制忽略，全部走内置 mock。
# 适合面试官 / 同事克隆后零配置体验：只需要一个 LLM Key 就能跑出完整流程。
DEMO_MODE=false

# ==== LLM Provider 选择 ====
# 支持：deepseek / openai / azure-openai / ollama
LLM_PROVIDER=deepseek

# ---- deepseek / openai（OpenAI 兼容协议）----
# DeepSeek：base_url=https://api.deepseek.com/v1，model=deepseek-chat
# 官方 OpenAI：base_url=https://api.openai.com/v1，model=gpt-4o-mini
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_MANAGER_MODEL=deepseek-chat

# ---- azure-openai（仅 LLM_PROVIDER=azure-openai 时需要）----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MANAGER_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# ---- ollama（本地 LLM，需先 ollama pull <model>）----
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MANAGER_MODEL=

# ==== MCP Servers (留空则走内置 mock，方便本地体验) ====
# 高德 MCP Server，例：https://mcp.amap.com/sse?key=YOUR_AMAP_KEY
AMAP_MCP_URL=
AMAP_API_KEY=
# 前端 JS API Key（在地图板块用）。没有就留空，会自动回退用 AMAP_API_KEY
# 申请地址：https://console.amap.com/dev/key/app  类型选『Web 端 (JS API)』
AMAP_JS_KEY=
# JS API 安全密钥（控制台分配）。没开『安全密钥校验』就留空
AMAP_JS_SECURITY=

# 小红书 MCP Server
XHS_MCP_URL=

# 12306 MCP Server （魔搭社区托管 Joooook/12306-mcp，免本地部署）
# 在 https://www.modelscope.cn/mcp/servers/@Joooook/12306-mcp 登录后取个人 SSE 端点：
# https://mcp.api-inference.modelscope.net/<your-token>/sse
TRAIN12306_MCP_URL=

# 酒店 MCP Server（默认 AIGOHOTEL：魔搭 yorklu/AI_Go_Hotel_MCP）
# 1. 申请 API Key：https://mcp.agentichotel.cn/apply
# 2. ModelScope 登录后拿专属 SSE 端点：https://www.modelscope.cn/mcp/servers/yorklu/AI_Go_Hotel_MCP
#    形如：https://mcp.api-inference.modelscope.net/<your-token>/sse
# 兼容：未设置 HOTEL_MCP_URL 时会回退读取旧名 CTRIP_MCP_URL
HOTEL_MCP_URL=
# CTRIP_MCP_URL=（已弃用，保留兼容）

# 飞常准 MCP Server（用于查机票）
# 在 ModelScope 登录后获取个人 SSE 端点，形如：
# https://mcp.api-inference.modelscope.net/<your-token>/sse
# 详情：https://www.modelscope.cn/mcp/servers/@variflight-ai/variflight-mcp
VARIFLIGHT_MCP_URL=

# ==== 记忆库（用户偏好 + 对话历史）====
# 留空 = 使用 SQLite：项目 data/memory.db（与旧版 memory.json 同目录）
# PostgreSQL 示例：DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/travelagent
# （需 pip 安装 asyncpg）
DATABASE_URL=
# 调试 ORM SQL 时设为 true
SQL_ECHO=

# ==== 鉴权（行程 / 票务记忆绑定真实用户）====
# false = 开发体验：聊天 JSON 里传 user_id，记忆接口用 ?user_id=
# true = 生产：必须先注册/登录，用 JWT（聊天与记忆均不再信任客户端传来的 user_id）
AUTH_REQUIRED=false
# AUTH_REQUIRED=true 时必须配置，建议 openssl rand -hex 32
JWT_SECRET=
# 访问令牌有效期（分钟），默认 10080 = 7 天
JWT_EXPIRE_MINUTES=10080

# ==== 服务 ====
APP_HOST=127.0.0.1
APP_PORT=8000

# ==== Observability (OpenTelemetry) ====
# 留空 = 不导出（生产时把 trace 关掉，本地开发推荐用 docker compose 起 jaeger）
# docker compose 模式下，compose 已配 OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# 本地裸跑想看 trace：手动起 jaeger 后设
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# 没装 jaeger 又想看 span 结构 → 设 OTEL_CONSOLE=true 打到 stdout
OTEL_CONSOLE=
